name: Build DEFCON EXE

on:
  push:
    branches: [ main, master ]
  workflow_dispatch:

jobs:
  build:
    runs-on: windows-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v4

    - name: Set up Python
      uses: actions/setup-python@v5
      with:
        python-version: '3.11'

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        pip install pyinstaller

    - name: Build EXE
      run: |
        pyinstaller --onefile --noconsole --name "DEFCON_TERMINAL" --icon=icon.ico defcon_terminal.py
      shell: bash

    - name: Upload EXE
      uses: actions/upload-artifact@v4
      with:
        name: DEFCON_TERMINAL_EXE
        path: dist/DEFCON_TERMINAL.exe
